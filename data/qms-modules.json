026","reviewDue":"18.01.2028","status":"current","longTitle":"QA-22.1 Quality Audit Management"},{"code":"QA-37","title":"Protected Disclosure Policy","cat":"QA","owner":"Director of Quality","version":"2.0","effective":"22.09.2025","reviewDue":"22.09.2026","status":"due","longTitle":"QA-37 Protected Disclosure Policy"},{"code":"QA-SOP-CMP-01","title":"Master Complaints Log (SOP)","cat":"QA","owner":"Complaints Officer","version":"1.0","effective":"15.01.2026","reviewDue":"15.01.2027","status":"current","longTitle":"QA-SOP-CMP-01 Master Complaints Log"}],"formCats":[{"key":"intake","label":"Intake & assessment","icon":"assignment_ind"},{"key":"consent","label":"Consent & agreement","icon":"handshake"},{"key":"careplan","label":"Care planning","icon":"clinical_notes"},{"key":"daily","label":"Daily visit records","icon":"fact_check"},{"key":"med","label":"Medication","icon":"medication"},{"key":"incident","label":"Incidents & complaints","icon":"crisis_alert"},{"key":"safe","label":"Safeguarding","icon":"shield"},{"key":"hr","label":"HR & supervision","icon":"badge"}],"forms":[{"name":"Referral Record","ref":"SOP-001","cat":"intake","purpose":"Captures a new referral at the point it arrives — source, date, Service User details, HSE reference and presenting needs.","owner":"Care Coordinator","systems":"CRM — Referrals","links":["SOP-001","GOV-25"]},{"name":"Comprehensive Needs Assessment","ref":"SOP-002","cat":"intake","purpose":"The rights-based home assessment of needs, goals and preferences that the care plan is built from. Scheduled within 7 working days of the HSE request.","owner":"Assessor / CSM","systems":"CRM — Service User file","links":["SOP-002"]},{"name":"Environmental / Home Risk Assessment","ref":"HS-04","cat":"intake","purpose":"Assesses the home environment for hazards before care begins and at review — access, trip hazards, equipment, pets, fire.","owner":"Assessor / CSM","systems":"Service User file","links":["HS-04"]},{"name":"Manual Handling Risk Assessment","ref":"HS-11","cat":"intake","purpose":"Assesses moving-and-handling needs and equipment (hoist, slide sheet) so only competent carers are allocated.","owner":"Assessor / CSM","systems":"Service User file","links":["HS-11"]},{"name":"Consent to Share Information","ref":"Appendix 3","cat":"consent","purpose":"Records the Service User’s consent to share their information with the HSE, GP and other providers.","owner":"Assessor / CSM","systems":"Service User file","links":["SOP-002","QM-06"]},{"name":"Consent to Prompt Medication","ref":"Appendix 4","cat":"consent","purpose":"Records consent for carers to prompt or assist with medication, and the agreed level of support.","owner":"Assessor / CSM","systems":"Service User file","links":["SOP-002","HS-18"]},{"name":"Care Agreement","ref":"GOV-12","cat":"consent","purpose":"The signed agreement between Liberty Living and the Service User setting out the service, rights and responsibilities.","owner":"CSM","systems":"Service User file","links":["GOV-12"]},{"name":"Home Support Care Plan","ref":"Appendix 6","cat":"careplan","purpose":"The person-centred plan of agreed goals, tasks, schedule and any medication prompting — signed and clinically approved before care starts.","owner":"CSM + Clinical Lead","systems":"CRM — Service User file","links":["SOP-002","GOV-35"]},{"name":"Care Plan Review Record","ref":"QA-22","cat":"careplan","purpose":"Records the scheduled and triggered reviews of the care plan and any changes to need.","owner":"CSM","systems":"Service User file","links":["QA-22"]},{"name":"LibertyLiving Record Sheet","ref":"SOP-017","cat":"daily","purpose":"The visit record the carer completes at every call — tasks delivered, observations and any change in the Service User.","owner":"HCA","systems":"CRM diary / paper record sheet","links":["SOP-017"]},{"name":"Point-of-Care Risk Assessment (PCRA) card","ref":"HS-34","cat":"daily","purpose":"The quick dynamic risk check the carer makes on arrival to choose the right PPE and precautions before any task.","owner":"HCA","systems":"Carried by carer","links":["HS-34"]},{"name":"Visit / CRM Diary Note","ref":"SOP-017","cat":"daily","purpose":"The clock-in / clock-out and short diary note submitted within the call via Careplanner.","owner":"HCA","systems":"Careplanner app","links":["SOP-017"]},{"name":"Medication Administration Record (MAR)","ref":"HS-18","cat":"med","purpose":"The running record of medication prompted or assisted at each visit.","owner":"HCA","systems":"Service User file / MAR chart","links":["HS-18"]},{"name":"Medication Error / Near-Miss Report","ref":"QA-13","cat":"med","purpose":"Records any medication error or near miss so the person’s safety is checked and the incident is managed.","owner":"HCA / Coordinator","systems":"CRM — Incident log","links":["QA-13","HS-18"]},{"name":"Incident Report","ref":"QA-13","cat":"incident","purpose":"The core incident form for any fall, injury, medication error, missed visit or environmental event — with the Category 1–4 rating.","owner":"Any staff member","systems":"CRM — Master Incident Log","links":["QA-13"]},{"name":"Body Map","ref":"QA-13","cat":"incident","purpose":"Records the location and description of any injury, mark or wound observed.","owner":"HCA","systems":"Attached to incident report","links":["QA-13"]},{"name":"Open Disclosure Record","ref":"QA-13","cat":"incident","purpose":"Records the open, honest conversation with the Service User / family after an incident that caused harm.","owner":"CSM / Clinical Lead","systems":"Service User file + incident record","links":["QA-13"]},{"name":"Complaint / Feedback Form","ref":"QA-03","cat":"incident","purpose":"Captures a complaint or piece of feedback in the person’s own words, with the acknowledgement and resolution timeline.","owner":"Complaints Officer / Coordinator","systems":"CRM — Master Complaints Log","links":["QA-03"]},{"name":"Safeguarding Concern Report","ref":"HS-23","cat":"safe","purpose":"Records a safeguarding concern or disclosure in the person’s exact words and routes it to the DSO the same day.","owner":"Any staff member → DSO","systems":"Safeguarding concern log","links":["HS-23"]},{"name":"Supervision Record","ref":"HR-14","cat":"hr","purpose":"Records the one-to-one supervision meeting — reflection, development, any concerns and actions.","owner":"Line manager","systems":"Staff file","links":["HR-14"]},{"name":"Spot-Check / Competency Assessment","ref":"HR-14","cat":"hr","purpose":"Records an observed field spot-check or competency sign-off against a skill (e.g. hoisting, medication).","owner":"CSM / assessor","systems":"Staff file","links":["HR-14"]},{"name":"Staff File Checklist","ref":"HR-05","cat":"hr","purpose":"The onboarding checklist — Garda vetting, references, right to work, qualifications and mandatory training.","owner":"Recruitment","systems":"Staff file","links":["HR-05"]}],"wfKpis":[{"name":"Mandatory training compliance","target":"≥95%","value":"92%","prev":"91%","tone":"amber","icon":"groups"},{"name":"Induction completed before 1st assignment","target":"100%","value":"97%","prev":"96%","tone":"amber","icon":"school"},{"name":"Shadowing completed before lone working","target":"100%","value":"95%","prev":"94%","tone":"amber","icon":"supervisor_account"},{"name":"Annual NCCA completed","target":"≥95%","value":"90%","prev":"92%","tone":"amber","icon":"assignment_ind"},{"name":"Garda vetting valid before commencement","target":"100%","value":"100%","prev":"100%","tone":"green","icon":"verified_user"},{"name":"Training plan reviewed annually","target":"≥90%","value":"88%","prev":"85%","tone":"amber","icon":"event_repeat"},{"name":"Supervision completed on schedule","target":"≥90%","value":"93%","prev":"90%","tone":"green","icon":"forum"},{"name":"Dementia programme before dementia allocation","target":"100%","value":"100%","prev":"100%","tone":"green","icon":"psychology"}],"readiness":[{"label":"Fully ready","count":118,"tone":"green","desc